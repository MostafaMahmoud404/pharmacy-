# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/pharmacy_db

# MongoDB Atlas (Production)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pharmacy_db?retryWrites=true&w=majority

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_2024
JWT_EXPIRE=7d

# ========================================
# EMAIL CONFIGURATION (Nodemailer)
# ========================================
# Gmail Example
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# Mailgun Example
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USER=postmaster@your-domain.com
# EMAIL_PASS=your_mailgun_password

# SendGrid Example
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=your_sendgrid_api_key

FROM_NAME=منصة الصيدلية
FROM_EMAIL=noreply@pharmacy.com

# ========================================
# FRONTEND CONFIGURATION
# ========================================
FRONTEND_URL=http://localhost:3000

# ========================================
# CLOUDINARY CONFIGURATION (للصور)
# ========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========================================
# PAYMENT GATEWAY (اختياري)
# ========================================
# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Paymob (مصر)
PAYMOB_API_KEY=your_paymob_api_key
PAYMOB_INTEGRATION_ID=your_integration_id

# ========================================
# SMS CONFIGURATION (اختياري)
# ========================================
# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Nexmo/Vonage
NEXMO_API_KEY=your_nexmo_api_key
NEXMO_API_SECRET=your_nexmo_api_secret
NEXMO_FROM_NUMBER=Pharmacy

# ========================================
# VIDEO CALL CONFIGURATION (اختياري)
# ========================================
# Agora
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate

# Twilio Video
TWILIO_VIDEO_API_KEY=your_twilio_video_key
TWILIO_VIDEO_API_SECRET=your_twilio_video_secret

# ========================================
# GOOGLE MAPS API (للتوصيل)
# ========================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# FILE UPLOAD LIMITS
# ========================================
MAX_FILE_SIZE=5242880
MAX_FILES_COUNT=5

# ========================================
# SESSION & COOKIES
# ========================================
SESSION_SECRET=your_session_secret_key
COOKIE_EXPIRE=30

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# ========================================
# REDIS (للـ Caching - اختياري)
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# SOCKET.IO
# ========================================
SOCKET_PORT=5001
SOCKET_PATH=/socket.io

# ========================================
# ADMIN CREDENTIALS (للحساب الأول)
# ========================================
ADMIN_EMAIL=admin@pharmacy.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Admin
ADMIN_PHONE=01000000000

# ========================================
# BUSINESS CONFIGURATION
# ========================================
# Delivery
FREE_DELIVERY_THRESHOLD=200
DELIVERY_FEE=30
MAX_DELIVERY_DISTANCE=50

# Taxes
TAX_PERCENTAGE=14
SERVICE_FEE_PERCENTAGE=2

# Consultation
MIN_CONSULTATION_FEE=100
MAX_CONSULTATION_FEE=1000

# Order
MIN_ORDER_AMOUNT=50
MAX_ORDER_AMOUNT=10000

# Prescription
PRESCRIPTION_VALIDITY_DAYS=30

# Working Hours
WORKING_HOURS_START=09:00
WORKING_HOURS_END=21:00

# ========================================
# NOTIFICATION SETTINGS
# ========================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_PUSH_NOTIFICATIONS=false

# ========================================
# BACKUP & MAINTENANCE
# ========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
MAINTENANCE_MODE=false

# ========================================
# ANALYTICS & MONITORING (اختياري)
# ========================================
# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn

# New Relic
NEW_RELIC_LICENSE_KEY=your_new_relic_key

# ========================================
# SOCIAL MEDIA (للمشاركة)
# ========================================
FACEBOOK_APP_ID=your_facebook_app_id
TWITTER_HANDLE=@pharmacy
INSTAGRAM_HANDLE=pharmacy_official

# ========================================
# MISC
# ========================================
APP_NAME=Pharmacy Platform
APP_URL=https://pharmacy.com
SUPPORT_EMAIL=support@pharmacy.com
SUPPORT_PHONE=01234567890